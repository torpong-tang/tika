generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  avatar    String?  @db.LongText
  role      String    @default("developer")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignedIssues Issue[]   @relation("AssignedIssues")
  reportedIssues Issue[]   @relation("ReportedIssues")
  comments       Comment[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issues Issue[]

  @@map("projects")
}

model Issue {
  id          String   @id @default(cuid())
  issueKey    String   @unique
  title       String
  description String?  @db.Text
  type        String   @default("bug")
  status      String   @default("open")
  priority    String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?    @relation("AssignedIssues", fields: [assigneeId], references: [id], onDelete: SetNull)

  reporterId String
  reporter   User     @relation("ReportedIssues", fields: [reporterId], references: [id], onDelete: Cascade)

  comments Comment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([status])
  @@index([priority])
  @@map("issues")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issueId  String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([authorId])
  @@map("comments")
}
